<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Only needed for the streak/journey enhancement (shared with the app).
	     The daily-quote widget works without this. -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.voxu.app</string>
	</array>
</dict>
</plist>
